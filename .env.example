POSTGRES_PASSWORD=localdev
INTERNAL_SECRET=dev-secret-change-in-prod
JWT_SECRET=dev-jwt-secret-minimum-32-chars-here

# LLM PROVIDER CONFIGURATION
#
# LOCAL DEVELOPMENT (default): uses the Ollama container.
# PRODUCTION: set LLM_PROVIDER=openai and provide OPENAI_API_KEY.

LLM_PROVIDER=ollama

# Ollama configuration (used when LLM_PROVIDER=ollama)

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_HARDWARE_TIER=2

# Tier defaults:
# 1 = 8GB VRAM    -> qwen3:8b primary,  qwen3:8b fast
# 2 = 12-16GB     -> qwen3:14b primary, qwen3:8b fast
# 3 = 24GB+ VRAM  -> qwen3:32b primary, qwen3:14b fast
# cpu = no GPU    -> qwen3:8b primary,  qwen3:8b fast

OLLAMA_PRIMARY_MODEL=qwen3:14b
OLLAMA_FAST_MODEL=qwen3:8b
OLLAMA_NUM_CTX_PRIMARY=16384
OLLAMA_NUM_CTX_FAST=8192
OLLAMA_TEMPERATURE=0.1
OLLAMA_KEEP_ALIVE=24h

# OpenAI configuration (used when LLM_PROVIDER=openai)

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2

# Agent timeout configuration

AGENT_CONNECT_TIMEOUT=10
AGENT_READ_TIMEOUT=360

# OpenTelemetry

OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# Production: replace with Azure Monitor OTLP endpoint
