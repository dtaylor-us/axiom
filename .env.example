POSTGRES_PASSWORD=localdev
INTERNAL_SECRET=dev-secret-change-in-prod
JWT_SECRET=dev-jwt-secret-minimum-32-chars-here

# ===========================================================
# LLM PROVIDER CONFIGURATION
# ===========================================================

LLM_PROVIDER=ollama
# "ollama" for local development (default)
# "openai" for production

# --- Ollama - macOS native install (REQUIRED for GPU) -------
#
# Ollama MUST be installed natively on macOS via Homebrew.
# Do NOT run Ollama in Docker on macOS - Docker Desktop uses
# a Linux VM that cannot access the Apple Silicon GPU (Metal).
# CPU-only inference is 5-10x slower and causes pipeline failures
# due to memory pressure and empty responses.
#
# Setup (one time):
#   brew install ollama
#   brew services start ollama
#   ollama pull qwen3:14b
#   ollama pull qwen3:8b
#
# Verify GPU is being used:
#   ollama run qwen3:8b "say hello"
#   # Should respond in under 3 seconds on M-series chips
#
# The agent container connects to native Ollama via:
OLLAMA_BASE_URL=http://host.docker.internal:11434
# host.docker.internal resolves to the macOS host automatically
# from inside Docker Desktop containers. No extra configuration.

OLLAMA_PRIMARY_MODEL=qwen3:14b
OLLAMA_FAST_MODEL=qwen3:8b
OLLAMA_NUM_CTX_PRIMARY=16384
OLLAMA_NUM_CTX_FAST=8192
OLLAMA_TEMPERATURE=0.1

# --- Hardware tiers for macOS Apple Silicon -----------------
#
# M1 / M2 (8GB unified memory):
#   OLLAMA_PRIMARY_MODEL=qwen3:8b
#   OLLAMA_FAST_MODEL=qwen3:8b
#   OLLAMA_NUM_CTX_PRIMARY=8192
#   OLLAMA_NUM_CTX_FAST=4096
#
# M1 Pro / M2 Pro (16GB unified memory): RECOMMENDED
#   OLLAMA_PRIMARY_MODEL=qwen3:14b
#   OLLAMA_FAST_MODEL=qwen3:8b
#   OLLAMA_NUM_CTX_PRIMARY=16384
#   OLLAMA_NUM_CTX_FAST=8192
#
# M1 Max / M2 Max / M3 Max (32-64GB unified memory):
#   OLLAMA_PRIMARY_MODEL=qwen3:32b
#   OLLAMA_FAST_MODEL=qwen3:14b
#   OLLAMA_NUM_CTX_PRIMARY=32768
#   OLLAMA_NUM_CTX_FAST=16384

# --- OpenAI (production) ------------------------------------
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-key-here
# OPENAI_MODEL=gpt-4o
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2

# Agent timeout configuration
AGENT_CONNECT_TIMEOUT=10
AGENT_READ_TIMEOUT=360

# --- OpenTelemetry / Jaeger ---------------------------------
# Leave empty in local development to disable metric/trace export.
# The default empty value prevents the 15-second UNIMPLEMENTED
# error spam when Jaeger is not running locally.
#
# In production (Azure AKS): set to http://jaeger:4317
OTEL_EXPORTER_OTLP_ENDPOINT=

# Set to true to completely disable the OTel SDK (no tracing at all)
OTEL_SDK_DISABLED=false

# Local password-reset email testing
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false
EMAIL_FROM_ADDRESS=noreply@aiarchitect.local
EMAIL_FROM_NAME=Archon
APP_BASE_URL=http://localhost:3000

# ─── SpecWeaver pillar ─────────────────────────────────────
SPECWEAVER_JWT_SECRET=
# Generate: openssl rand -hex 32

# ─── Axiom platform gateway ───────────────────────────────
AXIOM_PLATFORM_JWT_SECRET=
# Generate: openssl rand -hex 32

# ─── MinIO local object storage ───────────────────────────
# Production uses Azure Blob Storage instead
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
