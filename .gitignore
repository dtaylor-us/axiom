.env
*.env.local

# ========================
# Deployment — generated by scripts/azure-bootstrap.sh
# NEVER commit these files
# ========================
.deployment-config
.github-actions-credentials.json

# ========================
# Terraform
# ========================
terraform/environments/dev.tfvars
terraform/environments/prod.tfvars
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
# Note: terraform/.terraform.lock.hcl is NOT listed here —
# the lock file pins provider versions and must be committed.

